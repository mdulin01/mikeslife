# Copy to .env (and set the same vars in Vercel → Settings → Environment Variables).
# Leave these unset to run in DEMO mode (seed data, no auth, no persistence).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Lock the app to your Firebase Auth UID (Authentication → Users → copy UID).
# If set, only this user can sign in.
VITE_OWNER_UID=
